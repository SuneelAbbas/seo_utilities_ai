# ─── Server ────────────────────────────────────────────────
PORT=3000

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# Example: http://localhost:5173,https://myfrontend.vercel.app
# Use "*" to allow all origins (not recommended in production).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── API Authentication (SHARED — both Muffet & Citation) ──
# Clients must send this key in the `x-api-key` header.
# Generate a strong random key: openssl rand -hex 32
CRAWLER_API_KEY=change-me-to-a-random-secret

# ─── Muffet Defaults ───────────────────────────────────────
# Default number of concurrent requests for muffet (1–50).
# Higher values crawl faster but put more load on the target server.
MUFFET_DEFAULT_CONCURRENCY=10

# ─── AI Provider API Keys (Citation Tracker) ───────────────
# OpenAI API key (default provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic / Claude API key (optional — for model: "claude")
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini API key (optional — for model: "gemini")
# Get your key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ─── Playwright / Deep-Crawl (Orchestrator) ─────────────────────
# Setting this to "0" installs Chromium browsers inside node_modules/
# instead of ~/.cache/ms-playwright. Required on StackHost because the
# non-root user cannot write to the home-directory cache.
PLAYWRIGHT_BROWSERS_PATH=0
