# ─── Server ────────────────────────────────────────────────
PORT=3000

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# Example: http://localhost:5173,https://myfrontend.vercel.app
# Use "*" to allow all origins (not recommended in production).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── API Authentication (SHARED — both Muffet & Citation) ──
# Clients must send this key in the `x-api-key` header.
# Generate a strong random key: openssl rand -hex 32
CRAWLER_API_KEY=change-me-to-a-random-secret

# ─── Muffet Defaults ───────────────────────────────────────
# Default number of concurrent requests for muffet (1–50).
# Higher values crawl faster but put more load on the target server.
MUFFET_DEFAULT_CONCURRENCY=10

# ─── AI Provider API Keys (Citation Tracker) ───────────────
# OpenAI API key (default provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic / Claude API key (optional — for model: "claude")
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini API key (optional — for model: "gemini")
# Get your key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ─── Playwright / Deep-Crawl (Orchestrator) ─────────────────────
# Setting this to "0" installs Chromium browsers inside node_modules/
# instead of ~/.cache/ms-playwright. Required on StackHost because the
# non-root user cannot write to the home-directory cache.
PLAYWRIGHT_BROWSERS_PATH=0

# ─── AI Module — OpenRouter ────────────────────────────────
# OpenRouter provides unified access to multiple LLM models.
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ENABLED=true

# ─── AI Module — Defaults ──────────────────────────────────
# Default model to use when no model is specified in the request.
DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324

# ─── AI Module — Timeout & Retry ───────────────────────────
# Request timeout in milliseconds (default: 60000 = 60s)
AI_TIMEOUT_MS=60000
# Maximum number of retry attempts on failure (default: 3)
AI_MAX_RETRIES=3

# ─── AI Module — Rate Limiting ─────────────────────────────
# Maximum requests per time window (default: 60 per minute)
AI_RATE_LIMIT_MAX=60
# Rate limit window in milliseconds (default: 60000 = 1 minute)
AI_RATE_LIMIT_WINDOW_MS=60000

# ─── AI Module — Logging ───────────────────────────────────
# Enable/disable request logging (default: true)
AI_LOGGING_ENABLED=true
# Log level: debug | info | warn | error (default: info)
AI_LOG_LEVEL=info

# ─── AI Module — Cost Tracking ─────────────────────────────
# Enable/disable cost tracking (default: true)
AI_COST_TRACKING_ENABLED=true
# Default pricing fallback per 1M input tokens (USD)
AI_DEFAULT_INPUT_PRICE_PER_M=0.15
# Default pricing fallback per 1M output tokens (USD)
AI_DEFAULT_OUTPUT_PRICE_PER_M=0.60

# ─── AI Module — Feature Flags ─────────────────────────────
# Set to "false" to disable the entire AI module
AI_MODULE_ENABLED=true
